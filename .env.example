# Database Configuration
DATABASE_URL=postgresql://opssage:opssage123@localhost:5432/opssage
REDIS_URL=redis://localhost:6379

# API Keys
OPENAI_API_KEY=your-openai-api-key-here
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX=opssage-incidents

# Datadog Integration
DATADOG_API_KEY=your-datadog-api-key-here
DATADOG_APP_KEY=your-datadog-app-key-here

# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_SIGNING_SECRET=your-slack-signing-secret-here

# Microsoft Teams Integration
TEAMS_BOT_TOKEN=your-teams-bot-token-here
TEAMS_APP_ID=your-teams-app-id-here

# PagerDuty Integration
PAGERDUTY_API_KEY=your-pagerduty-api-key-here
PAGERDUTY_SERVICE_ID=your-pagerduty-service-id-here

# Security
JWT_SECRET=your-super-secret-jwt-key-here
API_KEY_SECRET=your-api-key-secret-here

# Service Configuration
API_GATEWAY_PORT=3000
INCIDENT_ANALYSIS_PORT=3001
DATA_COLLECTION_PORT=3002
AI_ENGINE_PORT=3003

# Environment
NODE_ENV=development
LOG_LEVEL=debug

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3004

# Kubernetes
KUBERNETES_CONFIG=./config/kubeconfig
